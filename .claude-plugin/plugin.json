{
  "name": "@cyanheads/gbif-biodiversity-mcp-server",
  "version": "0.2.4",
  "description": "Search GBIF species taxonomy, occurrence records, datasets, and publishers via MCP. STDIO or Streamable HTTP.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/gbif-biodiversity-mcp-server#readme",
  "repository": "https://github.com/cyanheads/gbif-biodiversity-mcp-server",
  "license": "Apache-2.0",
  "mcpServers": {
    "@cyanheads/gbif-biodiversity-mcp-server": {
      "command": "npx",
      "args": ["-y", "@cyanheads/gbif-biodiversity-mcp-server"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    }
  }
}
